# Copy to .env.local and fill values. .env.local is git-ignored.

# ── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/secondbrain

# ── Claude (Anthropic) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Auth (Clerk) ────────────────────────────────────────────────────────────
# Use pk_test_/sk_test_ locally, pk_live_/sk_live_ in production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app/dashboard

# ── Public app URL (used by Stripe success/cancel URLs, webhooks) ──────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Firecrawl (optional — URL ingest cleaner; falls back to cheerio) ───────
FIRECRAWL_API_KEY=fc-...

# ── Stripe (optional — only if billing enabled) ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Scheduler (protected cron tick endpoint) ────────────────────────────────
# Shared secret the external cron caller presents to POST /api/agents/scheduler/tick.
# In production it MUST be sent as `Authorization: Bearer <secret>` (the `?key=`
# query fallback is dev-only — query strings leak into proxy/CDN logs).
# Unset ⇒ the endpoint is disabled (returns 503). Never commit the real value.
# WARNING: this endpoint executes Agent runs across all users — anyone holding
# this secret can trigger runs. Treat it like a production credential.
SCHEDULER_CRON_SECRET=
# Max tick requests per IP per 60s window (brute-force / amplification backstop).
# Defaults to 12. A once-a-minute cron stays far under this.
SCHEDULER_TICK_RATE_LIMIT=12

# ── Upstream monitor (admin update alerts) ──────────────────────────────────
# A scheduled check polls a GitHub repo for new releases/commits and raises an
# in-app admin alert (Admin → Updates) when it advances. DETECTION ONLY — it
# never pulls or applies upstream code. The cron endpoint
# POST /api/admin/upstream/check reuses SCHEDULER_CRON_SECRET above (same Bearer
# auth + rate limit), so no new secret is required.
#
# Repo to watch ("owner/name"). Defaults to NousResearch/hermes-agent when unset.
UPSTREAM_REPO=NousResearch/hermes-agent
# Optional: a GitHub token ONLY to raise the API rate limit. Never required,
# never logged. A classic/fine-grained token with public read is plenty.
GITHUB_TOKEN=
# Optional: an https incoming-webhook (Slack/Discord/etc.) to also push the
# alert to. Unset => alerts still appear in the in-app Admin -> Updates feed.
ADMIN_ALERT_WEBHOOK_URL=
# Admin allow-list: comma/space separated Clerk user ids that can see the
# Admin -> Updates page + its API. Unset => nobody is admin.
ADMIN_USER_IDS=

# ── Telegram integration (chat with your squad) ─────────────────────────────
# One platform bot (create via @BotFather) serves all users. Users link their
# own chat with a one-time code; we store only their chat id, never messages.
# Unset ⇒ the Telegram feature is hidden/disabled (shows "coming soon").
TELEGRAM_BOT_TOKEN=
# The bot's @username (without @), used to build t.me deep links.
TELEGRAM_BOT_USERNAME=
# Shared secret Telegram echoes back on every webhook call (min 8 chars). Set
# once, then POST /api/admin/messaging/setup (admin) to register the webhook.
TELEGRAM_WEBHOOK_SECRET=
